# avoid sending rust artifacts to daemon
target/

# avoid sending frontend artifacts to daemon
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.svelte-kit/

# keep git history out of build context
.git/

# avoid baking runtime state into images
snapshots/
data/
tmp/

# prevent local secrets from entering context
config.toml
.env

# drop local-only workspace artifacts
.claude/
DIAGNOSIS.md
